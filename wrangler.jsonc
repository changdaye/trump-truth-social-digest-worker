{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "trump-truth-social-digest-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-24",
	"account_id": "d66336592b3f62650da1e5fa60e4a28c",
	"workers_dev": true,
	"preview_urls": false,
	"observability": {
		"enabled": true
	},
	"triggers": {
		"crons": [
			"0 0 * * *"
		]
	},
	"kv_namespaces": [
		{
			"binding": "RUNTIME_KV",
			"id": "daf66a68882342f2a008b37df68b0b87",
			"preview_id": "daf66a68882342f2a008b37df68b0b87"
		}
	],
	"ai": {
		"binding": "AI"
	},
	"d1_databases": [
		{
			"binding": "BRIEF_DB",
			"database_name": "trump-truth-social-digest",
			"database_id": "28bf8861-1a7e-4a78-b747-9d4d3684dad1",
			"migrations_dir": "migrations"
		}
	],
	"vars": {
		"DIGEST_INTERVAL_HOURS": "24",
		"HEARTBEAT_INTERVAL_HOURS": "24",
		"REQUEST_TIMEOUT_MS": "15000",
		"FETCH_WINDOW_HOURS": "24",
		"MAX_POSTS_PER_DIGEST": "30",
		"LLM_MODEL": "gpt-5.4",
		"WORKER_PUBLIC_BASE_URL": "https://trump-truth-social-digest-worker.5frhvfq5s2.workers.dev",
		"TRUMP_TRUTH_FEED_URL": "https://trumpstruth.org/feed",
		"FAILURE_ALERT_THRESHOLD": "1",
		"FAILURE_ALERT_COOLDOWN_MINUTES": "180"
	}
}
