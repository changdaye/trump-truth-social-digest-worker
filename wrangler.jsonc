{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "trump-truth-social-digest-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-24",
	"workers_dev": true,
	"preview_urls": false,
	"observability": {
		"enabled": true
	},
	"triggers": {
		"crons": [
			"0 */2 * * *"
		]
	},
	"kv_namespaces": [
		{
			"binding": "RUNTIME_KV",
			"id": "e2c06df95a7f45bfae27ee5c79b3bf29",
			"preview_id": "1b1576e8d8924659855587dcf8256a15"
		}
	],
	"ai": {
		"binding": "AI"
	},
	"d1_databases": [
		{
			"binding": "BRIEF_DB",
			"database_name": "trump-truth-social-digest",
			"database_id": "a522c64e-6506-43a8-a821-90081179f559",
			"migrations_dir": "migrations"
		}
	],
	"vars": {
		"DIGEST_INTERVAL_HOURS": "2",
		"HEARTBEAT_INTERVAL_HOURS": "24",
		"REQUEST_TIMEOUT_MS": "15000",
		"FETCH_WINDOW_HOURS": "2",
		"MAX_POSTS_PER_DIGEST": "30",
		"LLM_MODEL": "@cf/meta/llama-3.1-8b-instruct",
		"TRUMP_TRUTH_FEED_URL": "https://trumpstruth.org/feed",
		"FAILURE_ALERT_THRESHOLD": "1",
		"FAILURE_ALERT_COOLDOWN_MINUTES": "180"
	}
}